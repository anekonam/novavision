# NovaVision On-Premise Configuration
# Copy this file to .env and fill in the values

# Centre name (displayed in the portal)
NOVAVISION_CENTRE_NAME=My Rehabilitation Centre

# Database password (change this!)
NOVAVISION_DB_PASSWORD=ChangeThisToAStrongPassword!

# JWT signing secret (generate a random 64+ character string)
NOVAVISION_JWT_SECRET=

# Port to expose the web portal on (default 443)
NOVAVISION_PORT=443

# Container registry (leave default for NovaVision-hosted images)
NOVAVISION_REGISTRY=novavision
NOVAVISION_VERSION=latest
